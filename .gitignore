
# Git Ignore for k8s-idp

# Dependencies (never commit!)
node_modules/

# Secrets (never commit!)
*.key
*.pem
*.crt
*_secret.yaml
*_secret.env
.env
.env.*
.vault_pass

# GCP Service Account Keys
*-d0b8f9185818.json
sydk-ktcloud-*.json

# Generated files
*.generated.yaml
*.generated.json

# Local overrides
values-local.yaml
config-local.yaml

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
*.log

# Backup files
*.bak
*.backup

# Test outputs
_test/
*.test.yaml

# Kubeconfig files with tokens
kubeconfig/kubeconfig-*
kubeconfig/gke-burst
kubeconfig/gke_gcloud_auth_plugin_cache
