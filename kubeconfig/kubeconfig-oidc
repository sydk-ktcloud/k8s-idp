# kubectl OIDC 인증 kubeconfig 템플릿
#
# 팀원 개인 GitHub 계정으로 클러스터에 접근.
# Kubernetes audit log에 개인 identity(GitHub username)가 기록됨.
#
# 사전 조건:
#   brew install krew && kubectl krew install oidc-login
#   또는: https://github.com/int128/kubelogin#getting-started
#
# 사용법:
#   export KUBECONFIG=~/.kube/kubeconfig-oidc
#   kubectl get pods -n trip-app
#   → 브라우저가 열리며 GitHub 로그인 → Dex 인증 → kubelogin이 토큰 캐싱
#
# 권한은 GitHub org sydk-ktcloud 내 팀 멤버십에 따라 자동 부여:
#   sydk-ktcloud:platform   → team-platform ClusterRole
#   sydk-ktcloud:sre        → team-sre ClusterRole
#   sydk-ktcloud:security   → team-security ClusterRole (읽기 전용)
#   sydk-ktcloud:finops     → team-finops ClusterRole (secrets 제외 읽기)
#   sydk-ktcloud:developer  → team-developer Role (trip-app 네임스페이스)

apiVersion: v1
kind: Config
clusters:
  - name: k8s-idp
    cluster:
      server: https://100.64.0.1:6443
      insecure-skip-tls-verify: true

contexts:
  - name: k8s-idp
    context:
      cluster: k8s-idp
      user: oidc-user

current-context: k8s-idp

users:
  - name: oidc-user
    user:
      exec:
        apiVersion: client.authentication.k8s.io/v1beta1
        command: kubectl
        args:
          - oidc-login
          - get-token
          - --oidc-issuer-url=http://100.64.0.1:30556
          - --oidc-client-id=kubectl
          - --oidc-extra-scope=groups
          - --oidc-extra-scope=email
          - --oidc-extra-scope=profile
          - --listen-address=localhost:8000
        env: null
        interactiveMode: IfAvailable
