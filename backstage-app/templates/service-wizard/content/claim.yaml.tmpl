{# ── 사용자 응답 → 인프라 규모(scale) 자동 결정 ─────────────── #}
{%- if values.userCount === 'micro' -%}
  {%- set scale = 'dev' -%}
{%- elif values.userCount === 'small' and values.trafficPattern !== 'spiky' and values.availability !== 'high' -%}
  {%- set scale = 'dev' -%}
{%- elif values.userCount === 'small' -%}
  {%- set scale = 'standard' -%}
{%- elif values.userCount === 'medium' and values.trafficPattern === 'spiky' and values.availability === 'high' -%}
  {%- set scale = 'large' -%}
{%- elif values.userCount === 'medium' -%}
  {%- set scale = 'standard' -%}
{%- elif values.userCount === 'large' and values.trafficPattern === 'spiky' -%}
  {%- set scale = 'xlarge' -%}
{%- elif values.userCount === 'large' and (values.availability === 'high' or values.trafficPattern === 'steady') -%}
  {%- set scale = 'large' -%}
{%- elif values.userCount === 'large' -%}
  {%- set scale = 'standard' -%}
{%- else -%}
  {%- set scale = 'standard' -%}
{%- endif -%}
{# ────────────────────────────────────────────────────────── #}

{% if values.serviceType === 'web-api' %}
# ── 웹 API 서버: VM + 데이터베이스 ────────────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: WebApp
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  name: {{ values.componentName }}
  environment: {{ scale }}
  region: {{ values.region }}
  dbEngine: POSTGRES_15

{% elif values.serviceType === 'file-service' %}
# ── 파일 저장 서비스: GCS 버킷 ────────────────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: Bucket
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  name: {{ values.componentName }}
  location: US
  storageClass: STANDARD
  {%- if scale === 'large' or scale === 'xlarge' %}
  versioning: true
  {%- else %}
  versioning: false
  {%- endif %}

{% elif values.serviceType === 'container-app' %}
# ── 컨테이너 앱: GKE 클러스터 ────────────────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: Cluster
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  name: {{ values.componentName }}
  location: {{ values.region }}
  {%- if scale === 'dev' %}
  nodeCount: 1
  machineType: e2-medium
  {%- elif scale === 'standard' %}
  nodeCount: 3
  machineType: e2-medium
  {%- elif scale === 'large' %}
  nodeCount: 5
  machineType: e2-standard-4
  {%- else %}
  nodeCount: 5
  machineType: n2-standard-8
  {%- endif %}

{% elif values.serviceType === 'event-driven' %}
# ── 이벤트 기반 서비스: Pub/Sub ──────────────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: PubSub
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  name: {{ values.componentName }}
  {%- if scale === 'dev' %}
  messageRetentionDuration: "86400s"
  ackDeadlineSeconds: 30
  {%- elif scale === 'standard' %}
  messageRetentionDuration: "604800s"
  ackDeadlineSeconds: 60
  {%- else %}
  messageRetentionDuration: "604800s"
  ackDeadlineSeconds: 120
  {%- endif %}

{% elif values.serviceType === 'data-processing' %}
# ── 데이터 처리: 고성능 VM ────────────────────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: GCPInstance
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  name: {{ values.componentName }}
  region: {{ values.region }}
  zone: {{ values.region }}-a
  {%- if scale === 'dev' %}
  machineType: e2-standard-4
  diskSize: 100
  {%- elif scale === 'standard' %}
  machineType: e2-standard-8
  diskSize: 200
  {%- elif scale === 'large' %}
  machineType: n2-standard-16
  diskSize: 500
  {%- else %}
  machineType: n2-standard-32
  diskSize: 1000
  {%- endif %}

{% endif %}
