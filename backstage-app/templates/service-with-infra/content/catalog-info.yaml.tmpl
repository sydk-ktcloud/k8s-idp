apiVersion: backstage.io/v1alpha1
kind: System
metadata:
  name: {{ values.name }}
  description: {{ values.description }}
  annotations:
    github.com/project-slug: {{ values.destination.owner }}/{{ values.destination.repo }}
spec:
  owner: {{ values.owner }}
  domain: default
---
apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: {{ values.name }}-service
  description: {{ values.description }}
  tags:
    - {{ values.language }}
    - service
  annotations:
    github.com/project-slug: {{ values.destination.owner }}/{{ values.destination.repo }}
    backstage.io/techdocs-ref: dir:.
spec:
  type: service
  lifecycle: experimental
  owner: {{ values.owner }}
  system: {{ values.name }}
  dependsOn:
    - resource:default/{{ values.name }}-infra
---
apiVersion: backstage.io/v1alpha1
kind: Resource
metadata:
  name: {{ values.name }}-infra
  description: Infrastructure for {{ values.name }}
  tags:
    - infrastructure
    - {{ values.resourceType }}
  annotations:
    github.com/project-slug: {{ values.destination.owner }}/{{ values.destination.repo }}
spec:
  type: {{ values.resourceType }}
  lifecycle: experimental
  owner: {{ values.owner }}
  system: {{ values.name }}
