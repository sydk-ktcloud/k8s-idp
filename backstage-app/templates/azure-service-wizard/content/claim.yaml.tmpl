{# ── 사용자 응답 → 인프라 규모(scale) 자동 결정 ─────────────── #}
{%- if values.userCount === 'micro' -%}
  {%- set scale = 'dev' -%}
{%- elif values.userCount === 'small' and values.trafficPattern !== 'spiky' and values.availability !== 'high' -%}
  {%- set scale = 'dev' -%}
{%- elif values.userCount === 'small' -%}
  {%- set scale = 'standard' -%}
{%- elif values.userCount === 'medium' and values.trafficPattern === 'spiky' and values.availability === 'high' -%}
  {%- set scale = 'large' -%}
{%- elif values.userCount === 'medium' -%}
  {%- set scale = 'standard' -%}
{%- elif values.userCount === 'large' and values.trafficPattern === 'spiky' -%}
  {%- set scale = 'xlarge' -%}
{%- elif values.userCount === 'large' and (values.availability === 'high' or values.trafficPattern === 'steady') -%}
  {%- set scale = 'large' -%}
{%- elif values.userCount === 'large' -%}
  {%- set scale = 'standard' -%}
{%- else -%}
  {%- set scale = 'standard' -%}
{%- endif -%}
{# ────────────────────────────────────────────────────────── #}

{% if values.serviceType === 'web-api' %}
# ── 웹 API 서버: Azure VM + PostgreSQL ──────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: AzureVM
metadata:
  name: {{ values.componentName }}-vm
  namespace: {{ values.namespace }}
  labels:
    backstage.io/kubernetes-id: {{ values.componentName }}
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  resourceGroupName: {{ values.resourceGroupName }}
  location: {{ values.location }}
  {%- if scale === 'dev' %}
  vmSize: Standard_B2s
  diskSizeGb: 30
  {%- elif scale === 'standard' %}
  vmSize: Standard_D2s_v3
  diskSizeGb: 50
  {%- elif scale === 'large' %}
  vmSize: Standard_D4s_v3
  diskSizeGb: 100
  {%- else %}
  vmSize: Standard_D8s_v3
  diskSizeGb: 200
  {%- endif %}
  adminUsername: azureuser
  providerConfigRef:
    name: default
---
apiVersion: k8s-idp.example.org/v1alpha1
kind: AzureDatabase
metadata:
  name: {{ values.componentName }}-db
  namespace: {{ values.namespace }}
  labels:
    backstage.io/kubernetes-id: {{ values.componentName }}
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  resourceGroupName: {{ values.resourceGroupName }}
  location: {{ values.location }}
  engine: postgresql
  {%- if scale === 'dev' %}
  skuName: B_Standard_B1ms
  storageMb: 20480
  {%- elif scale === 'standard' %}
  skuName: GP_Standard_D2s_v3
  storageMb: 51200
  {%- elif scale === 'large' %}
  skuName: GP_Standard_D4s_v3
  storageMb: 102400
  {%- else %}
  skuName: GP_Standard_D8s_v3
  storageMb: 204800
  {%- endif %}
  providerConfigRef:
    name: default

{% elif values.serviceType === 'file-service' %}
# ── 파일 저장 서비스: Azure Blob Storage ─────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: AzureBlobStorage
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    backstage.io/kubernetes-id: {{ values.componentName }}
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  resourceGroupName: {{ values.resourceGroupName }}
  location: {{ values.location }}
  {%- if scale === 'dev' %}
  replication: LRS
  {%- else %}
  replication: GRS
  {%- endif %}
  providerConfigRef:
    name: default

{% elif values.serviceType === 'container-app' %}
# ── 컨테이너 앱: Azure VM Docker 호스트 ─────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: AzureVM
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    backstage.io/kubernetes-id: {{ values.componentName }}
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  resourceGroupName: {{ values.resourceGroupName }}
  location: {{ values.location }}
  {%- if scale === 'dev' %}
  vmSize: Standard_D2s_v3
  diskSizeGb: 50
  {%- elif scale === 'standard' %}
  vmSize: Standard_D4s_v3
  diskSizeGb: 100
  {%- elif scale === 'large' %}
  vmSize: Standard_D8s_v3
  diskSizeGb: 200
  {%- else %}
  vmSize: Standard_D16s_v3
  diskSizeGb: 500
  {%- endif %}
  adminUsername: azureuser
  providerConfigRef:
    name: default

{% elif values.serviceType === 'data-processing' %}
# ── 데이터 처리: 고성능 Azure VM ─────────────────────────────
apiVersion: k8s-idp.example.org/v1alpha1
kind: AzureVM
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    backstage.io/kubernetes-id: {{ values.componentName }}
  annotations:
    k8s-idp.example.org/service-type: "{{ values.serviceType }}"
    k8s-idp.example.org/user-count: "{{ values.userCount }}"
    k8s-idp.example.org/traffic-pattern: "{{ values.trafficPattern }}"
    k8s-idp.example.org/availability: "{{ values.availability }}"
spec:
  resourceGroupName: {{ values.resourceGroupName }}
  location: {{ values.location }}
  {%- if scale === 'dev' %}
  vmSize: Standard_D4s_v3
  diskSizeGb: 100
  {%- elif scale === 'standard' %}
  vmSize: Standard_D8s_v3
  diskSizeGb: 200
  {%- elif scale === 'large' %}
  vmSize: Standard_D16s_v3
  diskSizeGb: 500
  {%- else %}
  vmSize: Standard_D32s_v3
  diskSizeGb: 1000
  {%- endif %}
  adminUsername: azureuser
  providerConfigRef:
    name: default

{% endif %}
