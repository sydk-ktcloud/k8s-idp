{% set repoUrl = values.repoUrl %}
{% if repoUrl.startswith('https://github.com/') %}
  {% set repoParts = repoUrl.replace('https://github.com/', '').split('/') %}
  {% set repoOwner = repoParts[0] %}
  {% set repoName = repoParts[1] %}
{% else %}
  {% set repoOwner = 'unknown' %}
  {% set repoName = 'unknown' %}
{% endif %}
apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: {{ values.componentName }}
  description: "{{ values.description }}"
  annotations:
    github.com/project-slug: {{ repoOwner }}/{{ repoName }}
    backstage.io/source-location: url:https://github.com/{{ repoOwner }}/{{ repoName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    kubecost.com/service-label: {{ values.componentName }}
    kubecost.com/namespace: {{ values.namespace }}
    kubecost.com/owner: {{ values.owner }}
    kubecost.com/cost-center: {{ values.costCenter }}
  tags:
    - {{ values.serviceType }}
    - {{ values.userCount }}
    - azure
  links:
    - url: https://portal.azure.com
      title: Azure Portal
      icon: cloud
    {% if values.serviceType === 'web-api' %}
    - url: https://portal.azure.com/#browse/Microsoft.Compute%2FvirtualMachines
      title: Azure VM 확인
      icon: compute
    - url: https://portal.azure.com/#browse/Microsoft.DBforPostgreSQL%2FflexibleServers
      title: Azure Database 확인
      icon: database
    {% elif values.serviceType === 'file-service' %}
    - url: https://portal.azure.com/#browse/Microsoft.Storage%2FstorageAccounts
      title: Blob Storage 확인
      icon: storage
    {% elif values.serviceType === 'container-app' %}
    - url: https://portal.azure.com/#browse/Microsoft.Compute%2FvirtualMachines
      title: Azure VM (Docker) 확인
      icon: compute
    {% elif values.serviceType === 'data-processing' %}
    - url: https://portal.azure.com/#browse/Microsoft.Compute%2FvirtualMachines
      title: 고성능 VM 확인
      icon: compute
    {% endif %}
spec:
  type: {{ values.serviceType }}
  lifecycle: {{ values.lifecycleTier }}
  owner: {{ values.owner }}
