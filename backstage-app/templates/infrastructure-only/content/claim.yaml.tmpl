{% if values.resourceType == 'gcpinstance' -%}
apiVersion: k8s-idp.example.org/v1alpha1
kind: GCPInstance
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
spec:
  name: {{ values.componentName }}
  machineType: {{ values.vmMachineType }}
  region: {{ values.vmRegion }}
  zone: {{ values.vmZone }}
  diskSize: {{ values.vmDiskSize }}

{% elif values.resourceType == 'bucket' -%}
apiVersion: k8s-idp.example.org/v1alpha1
kind: Bucket
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
spec:
  name: {{ values.componentName }}
  location: {{ values.bucketLocation }}
  storageClass: {{ values.bucketStorageClass }}
  versioning: {{ values.bucketVersioning }}
{% elif values.resourceType === 'cluster' -%}
apiVersion: k8s-idp.example.org/v1alpha1
kind: Cluster
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
spec:
  name: {{ values.componentName }}
  location: {{ values.clusterLocation }}
  nodeCount: {{ values.clusterNodeCount }}
  machineType: {{ values.clusterMachineType }}
{% elif values.resourceType === 'database' -%}
apiVersion: k8s-idp.example.org/v1alpha1
kind: Database
metadata:
  name: {{ values.componentName }}
  namespace: {{ values.namespace }}
  labels:
    app.kubernetes.io/name: {{ values.componentName }}
    backstage.io/kubernetes-id: {{ values.componentName }}
    owner: {{ values.owner }}
    cost-center: {{ values.costCenter }}
    lifecycle-tier: {{ values.lifecycleTier }}
    expires-at: "{{ values.expiresAt }}"
spec:
  name: {{ values.componentName }}
  databaseVersion: {{ values.dbDatabaseVersion }}
  tier: {{ values.dbTier }}
  region: {{ values.dbRegion }}
  diskSize: {{ values.dbDiskSize }}
{% endif -%}
