apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: {{ componentName }}
  description: "AWS 인프라 리소스: {{ resourceType }}"
  tags:
    - infrastructure
    - aws
    - {{ resourceType }}
  annotations:
    github.com/project-slug: sydk-ktcloud/k8s-idp
spec:
  type: resource
  lifecycle: experimental
  owner: user:guest
  dependsOn:
    - resource:crossplane-claims
  links:
    - url: https://console.aws.amazon.com
      title: AWS Console
      icon: cloud
{% if resourceType == 'ec2instance' -%}
    - url: https://console.aws.amazon.com/ec2/v2/home#Instances
      title: EC2 Instances
      icon: compute
{% elif resourceType == 's3bucket' -%}
    - url: https://s3.console.aws.amazon.com/s3/buckets/{{ componentName }}
      title: S3 Bucket
      icon: storage
{% elif resourceType == 'ekscluster' -%}
    - url: https://console.aws.amazon.com/eks/home#/clusters
      title: EKS Clusters
      icon: kubernetes
{% elif resourceType == 'rdsdatabase' -%}
    - url: https://console.aws.amazon.com/rds/home#databases
      title: RDS Databases
      icon: database
{% endif -%}
